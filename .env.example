# =============================================================================
# Aboodhairsalon — Environment variables
# =============================================================================
# Copier vers .env.local pour dev local. Vercel : configurer via dashboard.
# Ne JAMAIS commit .env, .env.local — voir .gitignore
# =============================================================================

# ─── App URL ─────────────────────────────────────────────────────────────────
# En dev : http://localhost:3000
# En prod : https://aboodhairsalon.com (apex)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domaines des sous-espaces. En dev tous pointent sur le même localhost,
# le routing est fait par pathname (/client, /cashier, /manager). En prod :
#   - SITE_URL=https://aboodhairsalon.com (vitrine + booking client)
#   - CASHIER_URL=https://cashier.aboodhairsalon.com
#   - MANAGER_URL=https://manager.aboodhairsalon.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CASHIER_URL=http://localhost:3000
NEXT_PUBLIC_MANAGER_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
# Nouveau projet Supabase dédié à Aboodhairsalon (NE PAS réutiliser celui de
# System A). À créer manuellement dans le dashboard Supabase, region EU-Central
# ou proche de l'Égypte.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project ref pour la commande `pnpm db:types`
SUPABASE_PROJECT_REF=

# ─── Resend (emails transactionnels) ─────────────────────────────────────────
# Compte Resend dédié, domaine aboodhairsalon.com vérifié (DKIM + SPF + DMARC)
RESEND_API_KEY=
# Adresse expéditrice par défaut (override possible via salon_settings)
RESEND_FROM_EMAIL=noreply@aboodhairsalon.com
# Adresse à laquelle on envoie les notifs d'erreur Resend (optionnel)
RESEND_REPLY_TO=contact@aboodhairsalon.com

# ─── Sécurité — Tokens email + cron ──────────────────────────────────────────
# Secret HMAC pour signer les liens clients (?p=...). Générer 64 chars random.
CLIENT_TOKEN_SECRET=
# Secret pour authentifier les cron jobs Vercel
CRON_SECRET=

# ─── Push notifications (Web Push) ───────────────────────────────────────────
# Générer la paire VAPID avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Email de contact VAPID (requis par le standard)
VAPID_SUBJECT=mailto:contact@aboodhairsalon.com

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Optionnel — sans ça, rate-limit dégradé en mémoire (par instance Vercel).
# Compte Upstash, base Redis créée, region EU-Central proche d'Égypte.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Monitoring (optionnel) ──────────────────────────────────────────────────
# Sentry pour error tracking en prod. Sans clé, errors loggés en stderr.
SENTRY_DSN=

# ─── Timezone & locale ───────────────────────────────────────────────────────
# Fuseau horaire du salon (Alexandrie = EET). Override possible via salon_settings.
SALON_TIMEZONE=Africa/Cairo
# Locale par défaut si pas de cookie utilisateur
DEFAULT_LOCALE=fr
