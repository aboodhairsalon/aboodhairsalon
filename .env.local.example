# Copie ce fichier vers .env.local et remplis les valeurs.
# Lors du push sur Vercel, configure les mêmes vars dans les "Environment Variables".

# ─── Dev local ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CASHIER_URL=http://localhost:3000
NEXT_PUBLIC_MANAGER_URL=http://localhost:3000

# ─── Supabase (NOUVEAU projet dédié) ───────────────────────
# Récupérer depuis : https://supabase.com/dashboard/project/{ref}/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_PROJECT_REF=xxxxxx

# ─── Resend ────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=noreply@aboodhairsalon.com

# ─── Sécurité ──────────────────────────────────────────────
# openssl rand -hex 32
CLIENT_TOKEN_SECRET=
# openssl rand -hex 32
CRON_SECRET=

# ─── Push (npx web-push generate-vapid-keys) ───────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@aboodhairsalon.com

# ─── Upstash (optionnel) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Timezone ──────────────────────────────────────────────
SALON_TIMEZONE=Africa/Cairo
DEFAULT_LOCALE=fr
